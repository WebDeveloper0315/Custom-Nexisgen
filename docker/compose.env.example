# Host paths and deployment channel for nexis compose stacks.

# Required: host mount for bittensor wallet files.
BT_WALLET_HOST_PATH=~/.bittensor/wallets

# Host workdir (per-cycle scratch + training_state).
# IMPORTANT: this path is bind-mounted 1:1 into the validator/trainer
# containers so that paths the nexis process hands to `docker -v` resolve
# correctly against the host filesystem.  Must be an absolute writable path.
NEXIS_WORKDIR_HOST_PATH=/var/lib/nexis

# Image channel watched by watchtower. Pin a digest to disable auto-update.
NEXIS_VALIDATOR_IMAGE=rendixnetwork/nexis:latest

# Watchtower polling interval in seconds.
WATCHTOWER_POLL_INTERVAL=300

# App env files consumed by each container.
VALIDATOR_ENV_FILE=./validator.env
TRAINER_ENV_FILE=./trainer.env

# Trainer-only host paths (ignored by validator stack).
# Must point at the same host paths the trainer.env declares; sibling-container
# mounts resolve against the host filesystem, not the trainer's container fs.
NEXIS_TRAINER_NUM_GPUS=8
NEXIS_TRAINER_MODELS_DIR=/workspace/nexisgen/models
NEXIS_TRAINER_CONFIG_JSON=/workspace/nexisgen/config.json

# NB: eval data is no longer a static host path. The validator/trainer
# now sync the nexis-eval bucket into `<NEXIS_WORKDIR_HOST_PATH>/eval_data/`
# at the start of every cycle. Override the bucket via NEXIS_EVAL_* in the
# role env files only if you're not using the network default.

# Optional Grafana/Loki ports.
LOKI_PORT=3100
GRAFANA_PORT=3000
