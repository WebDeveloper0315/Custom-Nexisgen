# ─────────────────────────────────────────────────────────────────────────────
# Validation API (FastAPI + Postgres) — host-side AND container-side env.
#   docker compose --env-file validation-api.env \
#                  -f docker-compose.validation-api.yml up -d --build
# ─────────────────────────────────────────────────────────────────────────────

# Compose interpolation (host)
POSTGRES_DB=nexis_validation
POSTGRES_USER=nexis
POSTGRES_PASSWORD=nexis
# Loopback-only port for the API.  The compose file binds `127.0.0.1:<port>`
# so the service is never reachable from the public internet — host nginx
# terminates TLS for api.nexisgen.ai and proxy_passes to this port.
VALIDATION_API_PORT=8080
# Postgres has no host-side port at all (only reachable from sibling
# containers).  POSTGRES_HOST_PORT is intentionally omitted; use
# `docker exec -it nexis-validation-postgres psql ...` to debug.
NEXIS_VALIDATION_PGDATA=./data/postgres
VALIDATION_API_ENV_FILE=./validation-api.env

# Subnet wiring for the validator allowlist sync
NEXIS_NETUID=70
BT_NETWORK=finney

# Bittensor wallet for chain reads (no signing required for the API).
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=/root/.bittensor/wallets

# Postgres DSN is injected by docker-compose.validation-api.yml; uncomment to override.
# NEXIS_VALIDATION_API_POSTGRES_DSN=postgresql://nexis:nexis@postgres:5432/nexis_validation

# Auth + allowlist policy
NEXIS_VALIDATION_API_MIN_VALIDATOR_STAKE=5000
NEXIS_VALIDATION_API_ALLOWLIST_REFRESH_SEC=300
NEXIS_VALIDATION_API_AUTH_MAX_SKEW_SEC=300
NEXIS_VALIDATION_API_NONCE_MAX_AGE_SEC=86400

# Required for `DELETE /v1/invalid-hotkeys` admin reset.
NEXIS_VALIDATION_API_ADMIN_TOKEN=

# Shared `nexis-miner` bucket — the API uploads {validator_hotkey}.json and
# rewrites total_score.json on each POST /v1/training-scores, so it needs WRITE keys.
NEXIS_MINER_BUCKET=nexis-miner
NEXIS_MINER_ACCOUNT_ID=
NEXIS_MINER_READ_ACCESS_KEY=
NEXIS_MINER_READ_SECRET_KEY=
NEXIS_MINER_WRITE_ACCESS_KEY=
NEXIS_MINER_WRITE_SECRET_KEY=

# Global overlap snapshot bucket — REQUIRED for feature 6 (owner-triggered
# record_info.json update). The API needs full WRITE access here: when the
# OWNER validator POSTs vbench scores, the API pulls top-5 miners' dataset
# indexes from `nexis-miner` and merges them into `record_info.json` on
# THIS bucket. Without all six keys set, the API logs
#   "record_info coordinator: enabled=False reason=record_info store unavailable..."
# at startup and silently no-ops on every owner POST.
NEXIS_RECORD_INFO_BUCKET=nexis-record-info
NEXIS_RECORD_INFO_ACCOUNT_ID=
NEXIS_RECORD_INFO_READ_ACCESS_KEY=
NEXIS_RECORD_INFO_READ_SECRET_KEY=
NEXIS_RECORD_INFO_WRITE_ACCESS_KEY=
NEXIS_RECORD_INFO_WRITE_SECRET_KEY=
NEXIS_RECORD_INFO_OBJECT_KEY=record_info.json

# Owner hotkey gate — only POSTs from this hotkey trigger record_info updates.
NEXIS_OWNER_VALIDATOR_HOTKEY=5EJGfSvRcEGVQtqDuU7YYwuZRHmaktf6JEZDeFPyeXksiHrm

NEXIS_LOG_LEVEL=INFO
