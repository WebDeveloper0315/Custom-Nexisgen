# ─────────────────────────────────────────────────────────────────────────────
# Owner-trainer runtime env (consumed by nexis-trainer container).
# Copy to trainer.env, fill in, chmod 600.  Owner-only stack.
# ─────────────────────────────────────────────────────────────────────────────

# Bittensor / chain
NEXIS_NETUID=70
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=/root/.bittensor/wallets
NEXIS_BLOCK_POLL_SEC=6

NEXIS_LOG_LEVEL=INFO
NEXIS_WORKDIR=/var/lib/nexis
NEXIS_TRAIN_POLL_SEC=30

# R2 batch concurrency.
NEXIS_DOWNLOAD_CONCURRENCY=16
NEXIS_UPLOAD_CONCURRENCY=8
NEXIS_MINER_GATHER_CONCURRENCY=4

# Shared `nexis_miner` bucket — owner needs WRITE keys to upload eval outputs
# and TOTAL SCORE writes (writes are also performed by the API server).
NEXIS_MINER_BUCKET=nexis_miner
NEXIS_MINER_ACCOUNT_ID=
NEXIS_MINER_READ_ACCESS_KEY=
NEXIS_MINER_READ_SECRET_KEY=
NEXIS_MINER_WRITE_ACCESS_KEY=
NEXIS_MINER_WRITE_SECRET_KEY=

# Global overlap snapshot bucket (read-only).
NEXIS_RECORD_INFO_BUCKET=nexis-record-info
NEXIS_RECORD_INFO_ACCOUNT_ID=
NEXIS_RECORD_INFO_READ_ACCESS_KEY=
NEXIS_RECORD_INFO_READ_SECRET_KEY=
NEXIS_RECORD_INFO_OBJECT_KEY=record_info.json

# Validator API client (used to mark selected miners as `invalid`).
NEXIS_VALIDATION_API_URL=https://api.nexisgen.ai/v1/training-scores
NEXIS_VALIDATION_API_TIMEOUT_SEC=120

# Owner identity (this hotkey gate-keeps `nexis train`).
NEXIS_OWNER_VALIDATOR_HOTKEY=5EJGfSvRcEGVQtqDuU7YYwuZRHmaktf6JEZDeFPyeXksiHrm

# Trainer mounts.  These paths must be readable by sibling containers, so they
# must exist on the host AND be mirrored 1:1 into the trainer container.
# Eval data is auto-synced from the nexis-eval bucket to <workdir>/eval_data
# before every training cycle; no static eval-dir path needed.
NEXIS_TRAINER_NUM_GPUS=8
NEXIS_TRAINER_MODELS_DIR=/workspace/nexisgen/models
NEXIS_TRAINER_CONFIG_JSON=/workspace/nexisgen/config.json
NEXIS_TRAINER_DOCKER_IMAGE=rendixnetwork/train:latest
NEXIS_TRAINER_SHM_SIZE=16g
NEXIS_TRAINER_TIMEOUT_SEC=86400

# Eval-data bucket (network defaults are baked in; override only to repoint).
NEXIS_EVAL_BUCKET=nexis-eval
NEXIS_EVAL_ACCOUNT_ID=
NEXIS_EVAL_READ_ACCESS_KEY=
NEXIS_EVAL_READ_SECRET_KEY=
NEXIS_EVAL_PREFIX=eval_data/
