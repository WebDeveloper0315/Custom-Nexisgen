# ─────────────────────────────────────────────────────────────────────────────
# Validator runtime env (consumed by nexis-validator container).
# Copy to validator.env and fill in the blanks.
# ─────────────────────────────────────────────────────────────────────────────

# Bittensor / chain
NEXIS_NETUID=70
BT_NETWORK=finney
BT_WALLET_NAME=default
BT_WALLET_HOTKEY=default
BT_WALLET_PATH=/root/.bittensor/wallets
NEXIS_BLOCK_POLL_SEC=6

NEXIS_LOG_LEVEL=INFO
NEXIS_WORKDIR=/var/lib/nexis

# Loop pacing
NEXIS_TRAIN_POLL_SEC=30
NEXIS_SCORE_POLL_SEC=30

# R2 batch concurrency.
NEXIS_DOWNLOAD_CONCURRENCY=16
NEXIS_UPLOAD_CONCURRENCY=8
NEXIS_MINER_GATHER_CONCURRENCY=4

# Shared `nexis_miner` bucket — validators only need READ keys.
NEXIS_MINER_BUCKET=nexis-miner
NEXIS_MINER_ACCOUNT_ID=cce499ad4f3a4703b069771d8ff4215a
NEXIS_MINER_READ_ACCESS_KEY=c7df3d75bcf89b19e9fccd2866957922
NEXIS_MINER_READ_SECRET_KEY=d04e506a8a155a5e729ada81d2c54f5397f29e061672f2c78bf7b5a2731eda69

# Global overlap snapshot bucket (read-only on validator side).
NEXIS_RECORD_INFO_BUCKET=nexis-record-info
NEXIS_RECORD_INFO_ACCOUNT_ID=cce499ad4f3a4703b069771d8ff4215a
NEXIS_RECORD_INFO_READ_ACCESS_KEY=0fa291e03819c60474fed86a4932e652
NEXIS_RECORD_INFO_READ_SECRET_KEY=7bfbc213f3295c0a7f88db3f069490ce474e82520b4455b6a7bc7aa5e66224ee
NEXIS_RECORD_INFO_OBJECT_KEY=record_info.json

# Validator API client
NEXIS_VALIDATION_API_URL=https://api.nexisgen.ai/v1/training-scores
NEXIS_VALIDATION_API_TIMEOUT_SEC=120

# VBench scoring (sibling containers spawned via the host docker socket).
# Eval data is auto-synced from the nexis-eval bucket to <workdir>/eval_data
# before every scoring cycle; no static path needed.
NEXIS_VBENCH_DOCKER_IMAGE=rendixnetwork/vbench:latest
NEXIS_VBENCH_RESULTS_DIR=/workspace/VBench/results
NEXIS_VBENCH_DIMENSIONS=i2v_subject,i2v_background,subject_consistency,background_consistency,motion_smoothness,dynamic_degree,aesthetic_quality,imaging_quality
NEXIS_VBENCH_TIMEOUT_SEC=21600

# Eval-data bucket (network defaults are baked in; override only to repoint).
NEXIS_EVAL_BUCKET=nexis-eval
NEXIS_EVAL_ACCOUNT_ID=cce499ad4f3a4703b069771d8ff4215a
NEXIS_EVAL_READ_ACCESS_KEY=168d66ba8c6cacf91c6374b408a5d593
NEXIS_EVAL_READ_SECRET_KEY=3aa4440df9db6f77e8cba83d8d1252666775f282e2c65dcc0ce62b08dba4a8c4
NEXIS_EVAL_PREFIX=eval_data/

# Owner identity (read-only here so the validator knows who's allowed to train).
NEXIS_OWNER_VALIDATOR_HOTKEY=5EJGfSvRcEGVQtqDuU7YYwuZRHmaktf6JEZDeFPyeXksiHrm
